EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_API_URL=http://localhost:8000

# Supabase Auth (dashboard) required for email OTP sign-in:
# 1. Auth → URL Configuration → add http://localhost:8081 (Expo web) to Redirect URLs
# 2. Auth → Email Templates → Magic Link → body must include {{ .Token }} for 6-digit codes
#    (If the email only has a link, verify will return 403 / otp_expired)
