# Supabase
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_KEY=<anon-key-from-project-settings>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key-from-project-settings>

# Gemini (https://aistudio.google.com/)
GEMINI_API_KEY=

# App
APP_NAME="Civic Tracker AI"
DEBUG=True

# HF YOLO service (deploy huggingface-space/ first)
YOLO_SERVICE_URL=https://<your-user>-civic-yolo.hf.space
YOLO_SERVICE_TOKEN=<same value as API_TOKEN Space secret>

# Training (used by ml/ scripts; not loaded at runtime)
ROBOFLOW_API_KEY=
HF_TOKEN=
